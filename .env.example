# /home/gcjjyy/lab/dosbox/.env (gitignored)
PORT=5301
DOS_ROOT=/home/gcjjyy/dos
DOSBOX_ADMIN_PASSWORD=change-me-to-something-strong
SESSION_SECRET=run-`openssl rand -base64 32`-and-paste-it-here

# Public base URL the app is served from (behind Cloudflare). When set,
# rebuildBundle() pre-warms the Cloudflare edge cache for each new bundle
# version so the first real visitor doesn't pull the large bundle from the slow
# origin. Leave unset to disable pre-warming.
PUBLIC_BASE_URL=https://dosbox.gcjjyy.dev
