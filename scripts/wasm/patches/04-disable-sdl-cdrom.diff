@@ -191,11 +191,17 @@
 		}
 		/* Show list of cdroms */
 		if (cmd->FindExist("-cd",false)) {
+#if !defined(JSDOS)
 			int num = SDL_CDNumDrives();
    			WriteOut(MSG_Get("PROGRAM_MOUNT_CDROMS_FOUND"),num);
 			for (int i=0; i<num; i++) {
 				WriteOut("%2d. %s\n",i,SDL_CDName(i));
 			};
+#else
+			// Emscripten's SDL1 port has no SDL_CD API: no physical CD drives.
+			// CD *images* are still mountable via IMGMOUNT / MOUNT -t iso.
+			WriteOut(MSG_Get("PROGRAM_MOUNT_CDROMS_FOUND"),0);
+#endif
 			return;
 		}
 
