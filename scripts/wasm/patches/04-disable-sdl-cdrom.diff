diff -urN a/src/dos/dos_mscdex.cpp b/src/dos/dos_mscdex.cpp
--- a/src/dos/dos_mscdex.cpp	2026-05-20 11:01:03
+++ b/src/dos/dos_mscdex.cpp	2026-05-20 11:01:04
@@ -288,6 +288,14 @@
 		// Always use IOCTL in Linux or OS/2
 		cdrom[numDrives] = new CDROM_Interface_Ioctl();
 		LOG(LOG_MISC,LOG_NORMAL)("MSCDEX: IOCTL Interface.");
+#elif defined(JSDOS)
+		// Emscripten's SDL1 port lacks the SDL_CD API, so there is no physical
+		// CD-ROM interface. This branch is unreachable under JSDOS because
+		// CDROM_GetMountType() never reports a physical drive (type 0x00), but
+		// the fake interface keeps this compiling. CD *images* (type 0x01) and
+		// directories (type 0x02) are handled by the cases below.
+		cdrom[numDrives] = new CDROM_Interface_Fake;
+		LOG(LOG_MISC,LOG_NORMAL)("MSCDEX: No physical CD interface (JSDOS).");
 #else
 		// Default case windows and other oses
 		cdrom[numDrives] = new CDROM_Interface_SDL();
diff -urN a/src/dos/dos_programs.cpp b/src/dos/dos_programs.cpp
--- a/src/dos/dos_programs.cpp	2026-05-20 11:01:03
