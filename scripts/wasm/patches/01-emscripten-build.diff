 dnl Check for SDL
+if test x$EMSCRIPTEN_BUILD = xno ; then
 SDL_VERSION=1.2.0
 AM_PATH_SDL($SDL_VERSION,
             :,
@@ -46,8 +64,29 @@
 ;
 }
 ])],AC_MSG_RESULT([yes]),[
- AC_MSG_RESULT([no]) 
+ AC_MSG_RESULT([no])
  AC_MSG_ERROR([Only libSDL 1.2.X supported])])
+else
+dnl Emscripten: pull SDL1 from emcc's ports system. -sUSE_SDL=1 is passed to
+dnl both the compiler (resolves SDL.h) and the linker (resolves -lSDL).
+SDL_CFLAGS="-sUSE_SDL=1"
+SDL_LIBS="-sUSE_SDL=1"
+AC_SUBST(SDL_CFLAGS)
+AC_SUBST(SDL_LIBS)
+CPPFLAGS="$CPPFLAGS $SDL_CFLAGS"
+LIBS="$LIBS $SDL_LIBS"
+dnl Define JSDOS globally via CPPFLAGS. Autoconf substitutes CPPFLAGS into
+dnl every generated Makefile (all subdirectories), so emcc compiles in
+dnl src/dos/, src/hardware/, etc. all see -DJSDOS. automake's per-directory
+dnl AM_CPPFLAGS does NOT propagate to subdir Makefile.am, so the define must
+dnl live here to reach the SDL-CDROM guards in src/dos/{cdrom,dos_programs}.cpp.
+CPPFLAGS="$CPPFLAGS -DJSDOS"
+dnl DOSBox 0.74-3 is C++03-era and uses the 'register' storage-class keyword
+dnl (e.g. src/gui/render_templates_sai.h), which ISO C++17 removed and emsdk's
+dnl clang rejects as a hard error. Force C++14, where 'register' is merely
+dnl deprecated (a warning). Set on global CXXFLAGS so it reaches every subdir.
+CXXFLAGS="$CXXFLAGS -std=gnu++14"
+fi
 
