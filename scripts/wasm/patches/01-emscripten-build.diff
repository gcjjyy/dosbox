+dnl Detect Emscripten build (emconfigure sets $EMSCRIPTEN to the sysroot path
+dnl and/or the configure invocation passes --host=wasm32). Several library
+dnl probes below (AM_PATH_SDL via sdl-config, AC_CHECK_LIB against X11/GL/png/
+dnl SDL_net/SDL_sound/curses) misbehave under emscripten: they either run a
+dnl host-system helper script or AC_TRY_LINK against host libraries that the
+dnl emscripten sysroot can't satisfy. Skip them in that case.
+EMSCRIPTEN_BUILD=no
+case "$host" in
+    wasm32-*|*-emscripten*)
+        EMSCRIPTEN_BUILD=yes
+        ;;
+esac
+if test "x$EMSCRIPTEN" != "x"; then
+    EMSCRIPTEN_BUILD=yes
+fi
+AM_CONDITIONAL(EMSCRIPTEN_BUILD, test x$EMSCRIPTEN_BUILD = xyes)
+
