@@ -17,5 +17,66 @@
                hardware/serialport/libserial.a libs/gui_tk/libgui_tk.a
 
 EXTRA_DIST = winres.rc dosbox.ico
+
+if EMSCRIPTEN_BUILD
+# Emscripten build: emit dosbox0743.js + dosbox0743.wasm via emcc with Asyncify so the
+# DOS hot loop can yield to the JS event loop without blocking.
+#
+# Compile-time flags (-DJSDOS, -sUSE_SDL=1) are applied globally via CPPFLAGS in
+# configure.ac so they reach every subdirectory (src/dos/, src/hardware/, ...).
+# automake's AM_CPPFLAGS is per-directory and would NOT propagate, which is why
+# the JSDOS define lives in configure.ac, not here.
+# Link-time:
+#   -sASYNCIFY=1            allow blocking C calls to yield to JS.
+#   -sASYNCIFY_STACK_SIZE   conservative; tune in Phase C if "stack overflow" hits.
+#   -Oz -flto=thin         match jsdos release builds' small/fast artifacts.
+#   -sMALLOC=emmalloc      lower allocator overhead for browser-only runtime.
+#   -sTOTAL_MEMORY=64MB    jsdos baseline initial memory; growth remains enabled.
+#   -sALLOW_MEMORY_GROWTH=1 DOSBox can grow past 64 MB once a game loads.
+#   -sMODULARIZE=1 +
+#   -sEXPORT_NAME=createDosbox  -> the app/lib/dos-emulator.ts factory contract.
+#   -sENVIRONMENT=web       no Node/worker shim.
+#   -sEXPORTED_FUNCTIONS=_main
+#                           Patches 02/03 will add _send_key, _send_mouse, _exit_dosbox.
+#                           Bracketless form: emcc accepts comma-separated names
+#                           directly, which sidesteps m4's [ ] quote characters
+#                           when autoreconf regenerates Makefile.in.
+#   -sEXPORTED_RUNTIME_METHODS=ccall,FS,HEAPU8,HEAPF32,callMain
+#                           ccall for invoking the exported funcs from JS; FS to
+#                           mount the DOS image; HEAP views for frame/audio.
+AM_LDFLAGS = -sASYNCIFY=1 \
+             -sASYNCIFY_STACK_SIZE=16384 \
+             -Oz \
+             -flto=thin \
+             -sMALLOC=emmalloc \
+             -sTOTAL_STACK=1MB \
+             -sTOTAL_MEMORY=67108864 \
+             -sALLOW_MEMORY_GROWTH=1 \
+             -sMODULARIZE=1 \
+             -sEXPORT_NAME=createDosbox \
+             -sENVIRONMENT=web \
+             -sUSE_SDL=1 \
+             -sEXPORTED_FUNCTIONS=_main \
+             -sEXPORTED_RUNTIME_METHODS=ccall,FS,HEAPU8,HEAPF32,callMain
+
+# Under emcc, automake's link step typically produces dosbox.js (with EXEEXT=.js)
+# plus a sibling dosbox.wasm; on some configurations the link target is plain
+# "dosbox" (no extension) with dosbox.wasm alongside. The rename hook below
+# handles both layouts and renames to dosbox0743.{js,wasm} so build.sh's docker cp
+# can find them by their final names.
+all-local: dosbox0743.js
+
+dosbox0743.js: dosbox$(EXEEXT)
+	@echo "  RENAME   dosbox -> dosbox0743.js + dosbox0743.wasm"
+	@if [ -f dosbox.js ];   then mv dosbox.js   dosbox0743.js;   fi
+	@if [ -f dosbox.wasm ]; then mv dosbox.wasm dosbox0743.wasm; fi
+	@if [ -f dosbox ] && [ ! -f dosbox0743.js ]; then mv dosbox dosbox0743.js; fi
+	@sed -i 's|dosbox\.wasm|dosbox0743.wasm|g' dosbox0743.js
+	@test -f dosbox0743.js   || { echo "dosbox0743.js not produced"; exit 1; }
+	@test -f dosbox0743.wasm || { echo "dosbox0743.wasm not produced"; exit 1; }
+
+clean-local:
+	-rm -f dosbox0743.js dosbox0743.wasm dosbox.js dosbox.wasm
+endif
 
 
