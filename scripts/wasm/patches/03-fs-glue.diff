+#ifdef JSDOS
+/* ------------------------------------------------------------------------
+ * JS <-> C bridge
+ *
+ * EM_JS macros below register two callbacks that DOSBox invokes whenever a
+ * frame or audio chunk is produced. The JS wrapper sets `Module.onFrame` /
+ * `Module.onAudio` at startup; this is the entire reason patch 03 exists.
+ *
+ * The frame callback hands the JS side a pointer into the SDL surface's
+ * pixel buffer (BGRA8888 under SCREEN_SURFACE — DOSBox calls SDL_SetVideoMode
+ * with a 32 bpp surface, and on emscripten the SDL1 port stores frames in the
+ * Module.HEAPU8 view at `ptr`). JS reads `stride * h` bytes starting at `ptr`
+ * before returning — the buffer is overwritten on the next render pass.
+ *
+ * The audio callback receives a Float32Array of interleaved stereo samples
+ * already converted from the mixer's native Bit16s. We do the int16->float
+ * conversion in C (see js_emit_audio below) to keep audio-bus.ts's contract
+ * simple and to avoid burning JS time on a per-chunk loop.
+ *
+ * NOTE: see app/lib/dos-emulator.ts for the consumer side.
+ * ------------------------------------------------------------------------ */
+
+EM_JS(void, js_on_frame, (const uint8_t* ptr, int w, int h, int stride), {
+	if (Module["onFrame"]) Module["onFrame"](ptr, w, h, stride);
+});
+
+EM_JS(void, js_on_audio, (const float* samples, int n_samples, int sample_rate), {
+	if (Module["onAudio"]) Module["onAudio"](samples, n_samples, sample_rate);
+});
+
+/* Internal helper used by mixer.cpp's MIXER_CallBack. Lives in this TU so the
+ * EM_JS definition above is visible without exposing a header. mixer.cpp gets
+ * the prototype via an extern declaration guarded by JSDOS.
+ *
+ * `stream` is interleaved stereo int16 (AUDIO_S16SYS), `byte_len` bytes; we
+ * convert to a thread-local float scratch buffer at /32768.0 and forward.
+ * `byte_len/4` = sample frames (stereo); we report `n_samples` as the JS-side
+ * float count (= frames * 2) so the receiver can shape it however it wants.
+ */
+extern "C" void js_emit_audio(const int16_t* stream, int byte_len, int sample_rate) {
+	/* Static scratch — MIXER_CallBack is invoked from a single producer
+	 * (the SDL audio thread under native builds; the emcc SDL1 port runs
+	 * it on the main thread, also single-threaded). 16 KiB is large enough
+	 * for any reasonable mixer.blocksize at any sample rate we ship. */
+	static float scratch[16384];
+	int frames = byte_len / (int)(sizeof(int16_t) * 2); /* stereo frames */
+	int floats = frames * 2;
+	if (floats <= 0) return;
+	if (floats > (int)(sizeof(scratch) / sizeof(scratch[0]))) {
+		floats = (int)(sizeof(scratch) / sizeof(scratch[0]));
+	}
+	const float inv = 1.0f / 32768.0f;
+	for (int i = 0; i < floats; ++i) {
+		scratch[i] = (float)stream[i] * inv;
+	}
+	js_on_audio(scratch, floats, sample_rate);
+}
+
+/* ------------------------------------------------------------------------
+ * Input + lifecycle exports
+ *
+ * These four `_send_*` / `_exit_*` symbols are listed in
+ * EXPORTED_FUNCTIONS in src/Makefile.am (this patch updates that list).
+ * The JS wrapper calls them via Module.ccall(...).
+ *
+ * Input model: we synthesise an SDL_Event and push it onto SDL's queue. The
+ * existing GFX_Events() pump in this file (called once per Normal_Loop tick
+ * from src/dosbox.cpp) drains the queue and dispatches keys via the mapper
+ * and mouse motion/buttons via HandleMouse{Motion,Button}. No new dispatch
+ * path is needed — we deliberately mirror what a native SDL build sees from
+ * the OS event source.
+ *
+ * Keycode is the raw SDLKey value (SDLK_*); the JS-side keymap is responsible
+ * for translating browser KeyboardEvent.code into the SDL1 numeric constants.
+ *
+ * exit_dosbox() pushes SDL_QUIT; the GFX_Events loop catches that and
+ * throws(0), which unwinds main() and lets emscripten teardown happen
+ * naturally (Asyncify pauses don't unwind, so we have to take the SDL path).
+ * ------------------------------------------------------------------------ */
+
+extern "C" {
+
+EMSCRIPTEN_KEEPALIVE void send_key(int keycode, int down) {
+	SDL_Event ev;
+	memset(&ev, 0, sizeof(ev));
+	ev.type = down ? SDL_KEYDOWN : SDL_KEYUP;
+	ev.key.type = ev.type;
+	ev.key.state = down ? SDL_PRESSED : SDL_RELEASED;
+	ev.key.keysym.sym = (SDLKey)keycode;
+	ev.key.keysym.scancode = (SDL_Scancode)keycode; /* best-effort; mapper uses sym */
+	SDL_PushEvent(&ev);
+}
+
+EMSCRIPTEN_KEEPALIVE void send_mouse_motion(int x, int y) {
+	SDL_Event ev;
+	memset(&ev, 0, sizeof(ev));
+	ev.type = SDL_MOUSEMOTION;
+	ev.motion.type = SDL_MOUSEMOTION;
+	ev.motion.x = (Uint16)x;
+	ev.motion.y = (Uint16)y;
+	SDL_PushEvent(&ev);
+}
+
+EMSCRIPTEN_KEEPALIVE void send_mouse_button(int button, int pressed) {
+	SDL_Event ev;
+	memset(&ev, 0, sizeof(ev));
+	ev.type = pressed ? SDL_MOUSEBUTTONDOWN : SDL_MOUSEBUTTONUP;
+	ev.button.type = ev.type;
+	ev.button.button = (Uint8)button;
+	ev.button.state = pressed ? SDL_PRESSED : SDL_RELEASED;
+	SDL_PushEvent(&ev);
+}
+
+EMSCRIPTEN_KEEPALIVE void exit_dosbox(void) {
+	SDL_Event ev;
+	memset(&ev, 0, sizeof(ev));
+	ev.type = SDL_QUIT;
+	SDL_PushEvent(&ev);
+}
+
+} /* extern "C" */
+#endif /* JSDOS */
+
+
 #if C_OPENGL
 #include "SDL_opengl.h"
 
