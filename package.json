{
  "name": "dosbox",
  "version": "1.0.57",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "copy-jsdos": "rm -rf public/js-dos && mkdir -p public/js-dos/emulators && cp -r node_modules/js-dos/dist/emulators/* public/js-dos/emulators/",
    "build": "npm run copy-jsdos && react-router build",
    "dev": "npm run copy-jsdos && react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@react-router/node": "7.15.0",
    "@react-router/serve": "7.15.0",
    "isbot": "^5.1.36",
    "js-dos": "^8.3.20",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "7.15.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@react-router/dev": "7.15.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/yauzl": "^2.10.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^2.1.9",
    "yauzl": "^3.3.0"
  }
}
